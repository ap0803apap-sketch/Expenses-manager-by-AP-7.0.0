<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Transaction Mode (Online/Cash) -->
    <RadioGroup
        android:id="@+id/rg_transaction_mode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <RadioButton
            android:id="@+id/rb_online"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:checked="true"
            android:text="Online" />

        <RadioButton
            android:id="@+id/rb_cash"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cash" />
    </RadioGroup>

    <!-- Transaction Type (Money In/Out) -->
    <RadioGroup
        android:id="@+id/rg_transaction_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <RadioButton
            android:id="@+id/rb_money_in"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:checked="true"
            android:text="@string/money_in" />

        <RadioButton
            android:id="@+id/rb_money_out"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/money_out" />
    </RadioGroup>

    <!-- Amount -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:hintEnabled="false">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_amount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/amount_hint"
            android:textSize="18sp"
            android:padding="16dp"
            android:gravity="top|start"
            android:inputType="numberDecimal|textMultiLine"
            android:minLines="1"
            android:maxLines="10"
            android:scrollHorizontally="false" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Person -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:hintEnabled="false">

        <AutoCompleteTextView
            android:id="@+id/et_person"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/person_hint"
            android:textSize="18sp"
            android:padding="16dp"
            android:gravity="top|start"
            android:inputType="textCapWords|textMultiLine"
            android:minLines="1"
            android:maxLines="10"
            android:scrollHorizontally="false" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Payment App (hidden initially) -->
    <Spinner
        android:id="@+id/spinner_payment_app_dialog"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:spinnerMode="dropdown"
        android:theme="@style/OneUITheme"
        android:layout_marginBottom="16dp"
        android:minHeight="48dp"
        android:visibility="gone" />

    <!-- Description -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:hintEnabled="false">

        <AutoCompleteTextView
            android:id="@+id/et_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/description_hint"
            android:textSize="18sp"
            android:padding="16dp"
            android:gravity="top|start"
            android:inputType="textCapSentences|textMultiLine"
            android:minLines="1"
            android:maxLines="10"
            android:scrollHorizontally="false" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Time Picker -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_time_picker"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/select_time_optional"
        android:layout_marginTop="8dp"
        app:icon="@drawable/ic_oui_time" />

</LinearLayout>