<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".SettingsFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:text="@string/appearance"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="?attr/colorPrimary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"/>

        <RadioGroup
            android:id="@+id/rg_theme"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="16dp">

            <RadioButton
                android:id="@+id/rb_theme_system"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/follow_system_theme" />

            <RadioButton
                android:id="@+id/rb_theme_light"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/light_mode" />

            <RadioButton
                android:id="@+id/rb_theme_dark"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/dark_mode" />
        </RadioGroup>

        <com.google.android.material.divider.MaterialDivider android:layout_width="match_parent" android:layout_height="wrap_content" />

        <TextView
            android:text="@string/security"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="?attr/colorPrimary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_biometric"
            style="@style/Widget.Material3.CompoundButton.MaterialSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:text="@string/enable_biometric_lock"
            android:drawableStart="@drawable/finger"
            android:drawablePadding="16dp"
            android:textAppearance="?attr/textAppearanceBodyLarge" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_device_admin"
            style="@style/Widget.Material3.CompoundButton.MaterialSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:text="Device Admin Protection"
            android:drawableStart="@drawable/admin"
            android:drawablePadding="16dp"
            android:textAppearance="?attr/textAppearanceBodyLarge" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="40dp"
            android:text="Prevents unauthorized uninstallation and data clearing."
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:alpha="0.7" />

        <com.google.android.material.divider.MaterialDivider android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp"/>

        <TextView
            android:text="Payments"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="?attr/colorPrimary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_manage_payment_apps"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Manage Payment Apps"
            app:icon="@drawable/pay"
            app:iconGravity="textStart" />

        <com.google.android.material.divider.MaterialDivider android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp"/>

        <TextView
            android:text="Data Management"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="?attr/colorPrimary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_export_database"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Export"
                app:icon="@drawable/save" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_import_database"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Import"
                app:icon="@drawable/restore" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Note: Export your database before uninstalling to prevent permanent data loss."
            android:textAlignment="center"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorError" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/developer_info_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainerLow">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Title -->
                <TextView
                    android:text="About Developer"
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:textColor="?attr/colorPrimary"
                    android:layout_marginBottom="12dp" />

                <!-- Developer Name -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_oui3_account"
                        app:tint="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:layout_marginStart="12dp"
                        android:text="Developed by AP"
                        android:layout_height="wrap_content"
                        android:layout_width="match_parent"
                        android:textAppearance="?attr/textAppearanceBodyMedium" />
                </LinearLayout>

                <!-- Email -->
                <LinearLayout
                    android:id="@+id/layout_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="4dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/mail"
                        app:tint="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:layout_marginStart="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="ap0803apap@gmail.com"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorPrimary" />
                </LinearLayout>


                <!-- GitHub -->
                <LinearLayout
                    android:id="@+id/layout_github"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="4dp">

                    <ImageView
                        android:layout_width="17dp"
                        android:layout_height="20dp"
                        android:src="@drawable/github_mark"
                        app:tint="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:layout_marginStart="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="View source code on GitHub"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorPrimary" />
                </LinearLayout>


            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>


    </LinearLayout>
</ScrollView>